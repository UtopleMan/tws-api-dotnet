# Copy to `.env` (git-ignored) and fill in your IBKR *paper* account credentials.
# The same variables are read by the integration tests (via environment or user-secrets).
#
# IMPORTANT: headless container login (IBC) requires that TWO-FACTOR AUTH (2FA) is
# DISABLED on this paper login. IBKR allows disabling 2FA for paper accounts.

# IBKR paper account username / password
TWS_USERID=your_paper_username
TWS_PASSWORD=your_paper_password

# paper | live | both  — keep this as paper for testing
TRADING_MODE=paper

# Set to "yes" to forbid order placement/modification over the API (read-only).
READ_ONLY_API=no

# Optional: set a password to enable the VNC GUI on localhost:5900 (debug login issues).
VNC_SERVER_PASSWORD=

# Container time zone.
TIME_ZONE=Etc/UTC

# --- Tailscale (publishes the cpgateway REST API on your tailnet) ---
# Reusable/ephemeral auth key from https://login.tailscale.com/admin/settings/keys
TS_AUTHKEY=tskey-auth-xxxxxxxxxxxx
# Node name on the tailnet -> https://<TS_HOSTNAME>.<your-tailnet>.ts.net (tailscale serve, port 443)
TS_HOSTNAME=cpgateway
